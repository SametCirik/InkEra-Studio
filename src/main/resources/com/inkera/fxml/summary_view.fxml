<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.inkera.ui.controllers.HomeController"
      style="-fx-background-color: #2b2b2b; -fx-border-color: #4caf50; -fx-border-width: 1; -fx-padding: 20;">

    <Label text="%summary.title" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <ScrollPane fitToWidth="true" prefHeight="200" prefWidth="400" 
                style="-fx-background: transparent; -fx-background-color: transparent;" hbarPolicy="NEVER">
        <content>
            <Label text="Zincirlerinden kurtulan bir heretic'in, tanrılara karşı başlattığı amansız savaşın hikayesi... Kaderin zincirlerini kırmak için ne kadar ileri gidebilirsin?&#10;&#10;Yüzyıllardır süren sessizlik bozuldu. Gökyüzündeki tapınaklar birer birer düşerken, yeryüzündeki halklar özgürlükleri için ayaklanıyor. Ancak bu savaş sadece kılıçlarla değil, büyülü sözlerle ve unutulmuş teknolojilerle yapılıyor.&#10;&#10;(Buraya veritabanından gelen uzun metin gelecek...)" 
                   wrapText="true" 
                   style="-fx-text-fill: #ddd; -fx-font-size: 14px; -fx-line-spacing: 5;"/>
        </content>
    </ScrollPane>

    <VBox alignment="CENTER_RIGHT">
        <Button text="%summary.close" fx:id="closeButton" onAction="#closeSummaryDialog"
                style="-fx-background-color: #3c3f41; -fx-text-fill: white; -fx-cursor: hand;"/>
    </VBox>

</VBox>